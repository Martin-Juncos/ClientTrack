NODE_ENV=development
PORT=3001
APP_ORIGIN=http://localhost:5173
ALLOWED_APP_ORIGINS=
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clienttrack?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=clienttrack_session
ADMIN_USER_1_NAME=Administrador Uno
ADMIN_USER_1_EMAIL=admin1@example.com
ADMIN_USER_1_PASSWORD=replace_with_a_strong_password
ADMIN_USER_2_NAME=Administrador Dos
ADMIN_USER_2_EMAIL=admin2@example.com
ADMIN_USER_2_PASSWORD=replace_with_a_strong_password

# Optional SMTP config. Leave these commented to disable outbound email.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tu_cuenta@gmail.com
# SMTP_PASS=replace_with_google_app_password
# EMAIL_FROM=ClientTrack <tu_cuenta@gmail.com>
